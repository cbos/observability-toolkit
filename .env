# Customization can be done in .env.override
# you can use that using or use the just file:
# > docker compose --env-file .env --env-file .env.override up
# > just up

LOKI_IMAGE_NAME=grafana/loki:3.7.3
TEMPO_IMAGE_NAME=grafana/tempo:2.10.0
PROMETHEUS_IMAGE_NAME=prom/prometheus:v3.13.0
GRAFANA_IMAGE_NAME=grafana/grafana:13.1.0
GRAFANA_HOST_PORT=3000
OTEL_COLLECTOR_IMAGE_NAME=otel/opentelemetry-collector-contrib:0.155.0
OTEL_COLLECTOR_HOST_PORT_PROMETHEUS=8889
OTEL_COLLECTOR_HOST_PORT_GRPC=4317
OTEL_COLLECTOR_HOST_PORT_HTTP=4318
PROMTAIL_IMAGE_NAME=grafana/promtail:3.6.11
PYROSCOPE_IMAGE_NAME=grafana/pyroscope:1.18.0
PYROSCOPE_PORT=4040
BUSYBOX_IMAGE_NAME=busybox:1.38.0